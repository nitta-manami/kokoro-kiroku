<div class="min-h-screen bg-[#FAF8F5]">
  <main class="mx-auto max-w-md py-10">

    <div class="rounded-3xl bg-white p-6 shadow">
      <h2 class="mb-8 text-center text-2xl font-bold text-stone-700">
        みんなの記録
      </h2>

      <% if @health_records.any? %>

        <% @health_records.each do |health_record| %>

          <div class="mb-6 border-b border-stone-200 pb-6 last:mb-0 last:border-b-0 last:pb-0">

            <div class="px-2">

              <div class="flex items-center justify-between">

                <p class="font-medium text-stone-700">
                  <%= health_record.user.name %>
                </p>

                <p class="text-sm text-stone-500">
                  <%= health_record.created_at.strftime("%Y/%m/%d") %>
                </p>

              </div>

              <p class="mt-3 text-stone-700">
                <%= health_record.content %>
              </p>

            </div>

            <div class="mt-4 flex justify-end">

              <% if current_user.likes.exists?(health_record: health_record) %>

              <%= button_to "🧡 応援済み（#{health_record.likes.count}）",
              health_record_like_path(
              health_record,
              current_user.likes.find_by!(health_record: health_record)
              ),
              method: :delete,
              class: "rounded-full border border-orange-200 bg-orange-100 px-3 py-1 text-xs text-orange-700 transition hover:bg-orange-200" %>

              <% else %>

              <%= button_to "🤍 応援する（#{health_record.likes.count}）",
              health_record_likes_path(health_record),
              method: :post,
              class: "rounded-full border border-orange-200 px-3 py-1 text-xs text-orange-600 transition hover:bg-orange-50" %>

              <% end %>

            </div>

          </div>

        <% end %>

      <% else %>

        <div class="py-8 text-center text-stone-500">
          <p class="text-4xl">🌱</p>

          <p class="mt-2">
            まだ投稿はありません。
          </p>

          <p class="mt-1 text-sm">
            最初の投稿をしてみましょう。
          </p>
        </div>

      <% end %>

    </div>

  </main>
</div>