<div class="max-w-2xl mx-auto px-6 py-8">

  <%= link_to "← ホームへ",
              home_path,
              class: "text-stone-500 hover:text-orange-600" %>

  <h2 class="text-3xl font-bold text-center text-gray-700 mt-6 mb-8">
    みんなの記録
  </h2>

  <% if @health_records.any? %>

    <% @health_records.each do |health_record| %>

      <div class="bg-orange-50 border border-orange-200 rounded-xl shadow-sm p-5 mb-4">

        <div class="flex items-center justify-between">

          <div class="flex items-center gap-3">
            <p class="font-semibold text-stone-700">
              <%= health_record.user.name %>
            </p>

            <p class="text-sm text-stone-500">
              <%= health_record.created_at.strftime("%Y/%m/%d %H:%M") %>
            </p>
          </div>

          <%= button_to "🤍 応援する (#{health_record.likes.count})",
                        health_record_likes_path(health_record),
                        method: :post,
                        class: "rounded border px-3 py-1 text-sm text-orange-500 hover:bg-orange-50" %>

        </div>

        <p class="mt-3 whitespace-pre-wrap text-stone-700">
          <%= health_record.content %>
        </p>

      </div>

    <% end %>

  <% else %>

    <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 text-center text-stone-500">
      まだ投稿がありません🌸
    </div>

  <% end %>

</div>