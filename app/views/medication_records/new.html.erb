<div class="min-h-screen bg-[#FAF8F5]">

  <main class="max-w-md mx-auto">

    <div class="rounded-3xl bg-white p-10 shadow">
      <h2 class="mb-8 text-center text-2xl font-bold text-stone-700">
        おくすりの記録
      </h2>

      <%= form_with model: @medication_record, local: true do |f| %>

        <div class="mb-8">

          <div class="flex flex-col items-center gap-4">

            <label class="flex w-56 cursor-pointer items-center gap-3 rounded-xl border border-orange-200 bg-orange-50 px-4 py-3 transition hover:bg-orange-100">
              <%= f.radio_button :status, "taken",
              class: "h-5 w-5 text-orange-400 focus:ring-orange-300" %>
              <span class="text-stone-700">飲めた 😊</span>
            </label>

            <label class="flex w-56 cursor-pointer items-center gap-3 rounded-xl border border-orange-200 bg-orange-50 px-4 py-3 transition hover:bg-orange-100">
              <%= f.radio_button :status, "missed",
              class: "h-5 w-5 text-orange-400 focus:ring-orange-300" %>
              <span class="text-stone-700">飲めなかった 😢</span>
            </label>

          </div>
        </div>

        <div class="mt-10 flex justify-center">
          <%= f.submit "保存",
          class: "w-48 rounded-full bg-orange-100 py-4 text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
        </div>

      <% end %>

    </div>

  </main>

</div>
