<div class="max-w-2xl mx-auto px-6 py-8">
  <h2 class="text-3xl font-bold text-center text-gray-700 mt-6 mb-8">
    おくすりの記録一覧
  </h2>

  <% if @medication_records.any? %>
    <% @medication_records.each do |medication_record| %>
      <div class="bg-orange-50 border border-orange-200 rounded-xl shadow-sm p-5 mb-4">
        <div class="flex justify-between items-start">
          <p class="text-sm text-stone-500">
            <%= medication_record.recorded_at.strftime("%Y/%m/%d %H:%M") %>
          </p>

          <%= button_to "削除",
                        medication_record_path(medication_record),
                        method: :delete,
                        data: {
                          turbo_confirm: "この記録を削除しますか？"
                        },
                        class: "text-sm text-red-500 hover:text-red-700" %>
        </div>

        <p class="mt-3 text-xl font-semibold">
          <% if medication_record.taken? %>
            <span class="text-green-600">💊 飲めた</span>
          <% else %>
            <span class="text-red-500">😢 飲めなかった</span>
          <% end %>
        </p>
      </div>
    <% end %>
  <% else %>
    <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 text-center text-stone-500">
      まだおくすりの記録がありません🌸
    </div>
  <% end %>
</div>