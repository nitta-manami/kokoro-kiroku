<div class="min-h-screen bg-[#FAF8F5]">
  <main class="max-w-2xl mx-auto px-6 py-10">

    <div class="rounded-3xl bg-white p-8 shadow">
  <h2 class="mb-8 text-center text-2xl font-bold text-stone-700">
    おくすりの記録一覧
  </h2>

  <% if @medication_records.any? %>

    <% @medication_records.each do |medication_record| %>

      <div class="mb-5 border-b border-stone-200 pb-5 last:border-b-0">

        <div class="flex items-center justify-between">

          <p class="text-sm text-stone-500">
            <%= medication_record.recorded_at.strftime("%Y/%m/%d %H:%M") %>
          </p>

          <%= button_to "削除",
              medication_record_path(medication_record),
              method: :delete,
              data: { turbo_confirm: "この記録を削除しますか？"},
              class: "rounded-lg border border-stone-300 px-3 py-1 text-sm text-stone-600 transition hover:bg-stone-100" %>

        </div>

        <div class="mt-4 flex justify-center">

          <% if medication_record.taken? %>

            <span class="rounded-full bg-green-100 px-5 py-2 font-medium text-green-700">
              💊 飲めた
            </span>

          <% else %>

            <span class="rounded-full bg-red-100 px-5 py-2 font-medium text-red-600">
              😢 飲めなかった
            </span>

          <% end %>

        </div>

      </div>

    <% end %>

  <% else %>

    <div class="py-8 text-center text-stone-500">
      <p class="text-4xl">🌱</p>
      <p class="mt-2">まだおくすりの記録はありません。</p>
      <p class="mt-1 text-sm">
        今日のおくすりを記録してみましょう。
      </p>
    </div>

  <% end %>

    </div>

  </main>
</div>