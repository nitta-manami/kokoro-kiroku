<div class="min-h-screen bg-[#FAF8F5]">
  <main class="mx-auto max-w-3xl px-6 py-10">
    <div class="rounded-3xl bg-white p-8 shadow">

      <h2 class="text-center text-3xl font-bold text-stone-700">
        <%= current_user.name %>さん、おかえりなさい🌸
      </h2>

      <p class="mt-3 text-center text-stone-500">
        今日も無理せず、自分のペースで過ごしましょう。
      </p>

      <!-- ボタン -->
      <div class="mt-8 grid grid-cols-2 gap-4">

        <%= link_to "💊 おくすりを記録する",
          new_medication_record_path,
          class: "rounded-xl bg-orange-100 py-4 text-center text-stone-700 shadow transition hover:bg-orange-200" %>

        <%= link_to "📝 体調を記録する",
          new_health_record_path,
          class: "rounded-xl bg-orange-100 py-4 text-center text-stone-700 shadow transition hover:bg-orange-200" %>

        <%= link_to "💊 おくすり一覧",
          medication_records_path,
          class: "rounded-xl bg-orange-100 py-4 text-center text-stone-700 shadow transition hover:bg-orange-200" %>

        <%= link_to "📝 体調一覧",
          health_records_path,
          class: "rounded-xl bg-orange-100 py-4 text-center text-stone-700 shadow transition hover:bg-orange-200" %>

      </div>

      <div class="mt-4">
        <%= link_to "🌏 みんなの記録",
          public_health_records_path,
          class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-stone-700 shadow transition hover:bg-orange-200" %>
      </div>

    </div>

    <!-- 最近の記録 -->
    <div class="mt-8 rounded-3xl bg-white p-8 shadow">

      <h2 class="mb-6 text-center text-2xl font-bold text-stone-700">
        最近の記録
      </h2>

      <% if @recent_health_records.any? %>

        <% @recent_health_records.each do |record| %>

          <div class="mb-4 border-b border-stone-100 pb-4 last:border-b-0">

            <p class="text-center text-sm text-stone-500">
              <%= record.created_at.strftime("%Y/%m/%d") %>
            </p>

            <p class="mt-2 text-center text-stone-700">
              <%= truncate(record.content, length: 50) %>
            </p>

          </div>

        <% end %>

      <% else %>

        <div class="py-6 text-center text-stone-500">
          <p class="text-4xl">🌱</p>
          <p class="mt-2">まだ体調の記録はありません。</p>
          <p class="mt-1 text-sm">
            今日の気持ちを記録してみましょう。
          </p>
        </div>

      <% end %>

    </div>

  </main>
</div>