<div class="min-h-screen bg-[#FAF8F5]">

  <main class="max-w-3xl mx-auto px-6 py-10">

    <div class="rounded-2xl bg-white p-8 shadow-sm">
      <h2 class="text-3xl font-bold text-stone-700">
        <%= current_user.name %>さん、おかえりなさい🌸
      </h2>

      <p class="mt-3 text-stone-500">
        今日も無理せず、自分のペースで過ごしましょう。
      </p>
    </div>


    <div class="mt-10 space-y-4">

      <%= link_to "💊 おくすりを記録する",
      new_medication_record_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
      
      <%= link_to "💊 おくすりの記録一覧",
      medication_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>

      <%= link_to "体調を記録する",
      new_health_record_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    
      <%= link_to "📝 体調の記録一覧",
      health_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    
      <%= link_to "みんなの記録", 
      public_health_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    </div>

    <div class="mt-12 rounded-2xl bg-white p-6 shadow-sm">
        <h3 class="text-xl font-semibold text-stone-700">
        最近の記録
        </h3>

        <p class="mt-4 text-stone-500">
          まだ記録はありません。
        </p>
    </div>


  </main>

</div>