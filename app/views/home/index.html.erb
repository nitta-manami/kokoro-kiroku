<div class="min-h-screen bg-[#FAF8F5]">

  <main class="max-w-3xl mx-auto px-6 py-10">

    <div class="rounded-2xl bg-white p-8 shadow-sm">
      <h2 class="text-3xl font-bold text-stone-700">
        <%= current_user.name %>さん、おかえりなさい🌸
      </h2>

      <p class="mt-3 text-stone-500">
        今日も無理せず、自分のペースで過ごしましょう。
      </p>
    </div>


    <div class="mt-10 space-y-4">

      <%= link_to "💊 おくすりを記録する",
      new_medication_record_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
      
      <%= link_to "💊 おくすりの記録一覧",
      medication_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>

      <%= link_to "📝 体調を記録する",
      new_health_record_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    
      <%= link_to "📝 体調の記録一覧",
      health_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    
      <%= link_to "みんなの記録", 
      public_health_records_path,
      class: "block w-full rounded-xl bg-orange-100 py-4 text-center text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>
    </div>

    <div class="mt-8 rounded-3xl bg-white p-8 shadow">
      <h2 class="mb-6 text-2xl font-bold text-stone-700">
        最近の記録
      </h2>

      <% if @recent_health_records.any? %>
      <% @recent_health_records.each do |record| %>
      <div class="mb-4 border-b border-stone-100 pb-4 last:border-b-0">
        <p class="text-sm text-stone-500">
          <%= record.created_at.strftime("%Y/%m/%d") %>
        </p>

        <p class="mt-2 text-stone-700">
          <%= truncate(record.content, length: 50) %>
        </p>
      </div>
    <% end %>

  <% else %>
    <p class="text-stone-500">
      まだ記録はありません。
    </p>
  <% end %>
</div>

  </main>

</div>