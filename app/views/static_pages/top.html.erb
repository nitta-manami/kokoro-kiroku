<div class="min-h-screen bg-stone-50 flex flex-col items-center pt-20">

  <h1 class="text-6xl font-semibold text-stone-700 tracking-wide">
    こころきろく
  </h1>

  <div class="w-24 h-px bg-stone-300 mt-6"></div>

  <p class="mt-8 text-center text-xl leading-10 text-stone-600">
    服薬の記録や体調の記録をしつつ、<br>
    病気と闘う人たちと繋がれるアプリです
  </p>

  <div class="mt-14 w-full max-w-md px-6">

    <% if user_signed_in? %>

    <%= link_to "ログアウト",
        destroy_user_session_path,
        data: { turbo_method: :delete },
        class: "block w-full rounded-full bg-red-200 py-4 text-center text-xl text-stone-700 shadow hover:bg-red-300 transition" %>

    <% else %>

    <%= link_to "ログイン",
        new_user_session_path,
        class: "block w-full rounded-full bg-green-200 py-4 text-center text-xl text-stone-700 shadow hover:bg-green-300 transition" %>

    <%= link_to "新規登録",
        new_user_registration_path,
        class: "block w-full rounded-full bg-orange-100 py-4 mt-6 text-center text-xl text-stone-700 shadow hover:bg-orange-200 transition" %>

    <% end %>

  </div>

</div>