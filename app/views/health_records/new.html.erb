<div class="min-h-screen bg-[#FAF8F5]">

  <header class="relative flex justify-center py-6">
    <h1 class="text-3xl font-bold text-stone-700">
      体調の記録
    </h1>

    <%= link_to "← ホーム", home_path,
        class: "absolute left-6 top-1/2 -translate-y-1/2 text-stone-500 hover:underline" %>
  </header>

  <main class="max-w-md mx-auto">

    <div class="rounded-2xl bg-white p-8 shadow-sm">

      <%= form_with model: @health_record, local: true do |f| %>

        <div class="mb-8">
          <%= f.label :content, "今日の体調", class: "mb-2 block text-stone-700" %>

          <%= f.text_area :content,
              rows: 6,
              maxlength: 200,
              placeholder: "今日はどんな一日でしたか？",
              class: "w-full rounded-lg border border-stone-300 p-3 focus:border-orange-300 focus:outline-none" %>

          <p class="mt-2 text-sm text-stone-500">
            200文字以内で入力してください。
          </p>
        </div>

        <%= f.submit "保存",
            class: "w-full rounded-full bg-orange-100 py-4 text-lg text-stone-700 shadow hover:bg-orange-200 transition" %>

      <% end %>

    </div>

  </main>

</div>