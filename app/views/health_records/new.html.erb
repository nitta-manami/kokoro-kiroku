<div class="min-h-screen bg-[#FAF8F5]">
  <main class="max-w-md mx-auto py-10">

    <div class="rounded-3xl bg-white p-8 shadow">
      <h2 class="mb-8 text-center text-2xl font-bold text-stone-700">
        体調の記録
      </h2>

      <%= form_with model: @health_record, local: true do |f| %>

        <div class="mb-8">
          <%= f.text_area :content,
              rows: 6,
              maxlength: 200,
              placeholder: "今日はどんな一日でしたか？",
              class: "w-full rounded-xl border border-stone-300 p-3 focus:border-orange-300 focus:outline-none" %>

          <p class="mt-2 text-center text-sm text-stone-500">
            200文字以内で入力できます😊
          </p>
        </div>

        <div class="flex justify-center">
          <%= f.submit "保存",
              class: "w-48 rounded-full bg-orange-100 py-4 text-lg text-stone-700 shadow transition hover:bg-orange-200" %>
        </div>

      <% end %>

    </div>

  </main>
</div>