<div class="min-h-screen bg-[#FAF8F5]">
  <main class="mx-auto max-w-md py-10">

    <div class="rounded-3xl bg-white p-6 shadow">
      <h2 class="mb-8 text-center text-2xl font-bold text-stone-700">
        体調の記録一覧
      </h2>

      <% if @health_records.any? %>

        <% @health_records.each do |health_record| %>

          <div class="mb-6 border-b border-stone-200 pb-6 last:mb-0 last:border-b-0 last:pb-0">

            <div class="px-2">
              <p class="text-sm text-stone-500">
                <%= health_record.created_at.strftime("%Y/%m/%d") %>
              </p>

              <p class="mt-3 text-stone-700">
                <%= health_record.content %>
              </p>
            </div>

            <div class="mt-5 flex justify-end gap-3">
              <%= link_to "編集",
                  edit_health_record_path(health_record),
                  class: "rounded-full border border-orange-200 px-4 py-2 text-sm text-orange-600 transition hover:bg-orange-50" %>

              <%= button_to "削除",
                  health_record_path(health_record),
                  method: :delete,
                  data: {
                    turbo_confirm: "この記録を削除しますか？"
                  },
                  class: "rounded-full border border-red-200 px-4 py-2 text-sm text-red-500 transition hover:bg-red-50" %>
            </div>

          </div>

        <% end %>

      <% else %>

        <div class="py-8 text-center text-stone-500">
          <p class="text-4xl">🌱</p>

          <p class="mt-2">
            まだ体調の記録はありません。
          </p>

          <p class="mt-1 text-sm">
            今日の気持ちを記録してみましょう。
          </p>
        </div>

      <% end %>

    </div>

  </main>
</div>